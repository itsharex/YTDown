{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "opener:default",
    "core:app:default",
    "core:path:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "dialog:default",
    "allow-add-playlist-item",
    "allow-add-url-to-list",
    "allow-cancel-download",
    "allow-check-ytdlp-update",
    "allow-create-playlist",
    "allow-create-url-list",
    "allow-delete-file",
    "allow-delete-playlist",
    "allow-fetch-formats",
    "allow-get-all-settings",
    "allow-get-download",
    "allow-get-playlist-items",
    "allow-get-setting",
    "allow-get-ytdlp-info",
    "allow-install-ytdlp",
    "allow-import-cookies-from-browser",
    "allow-import-url-list",
    "allow-list-library",
    "allow-list-playlists",
    "allow-list-url-lists",
    "allow-move-file",
    "allow-pause-download",
    "allow-resume-download",
    "allow-reveal-in-finder",
    "allow-search-library",
    "allow-set-cookie-file",
    "allow-set-setting",
    "allow-set-ytdlp-path",
    "allow-start-download",
    "allow-fetch-playlist-items",
    "allow-toggle-favorite",
    "allow-update-ytdlp",
    "allow-get-browser-url",
    "allow-check-safari-access"
  ]
}
